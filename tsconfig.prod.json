{
    "extends": "./tsconfig.base.json",
    "compilerOptions": {
        "sourceMap": false,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "removeComments": true
    },
    "exclude": [
        "node_modules",
        "dist",
        "tests",
        "**/*.test.ts",
        "**/*.spec.ts"
    ]
}